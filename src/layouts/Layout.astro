---
import '../styles/global.css';
import CustomCursor from '../components/React/CustomCursor';
import CookieConsent from '../components/React/CookieConsent';
import DigiChat from '../components/React/AI/DigiChat';
import Analytics from '@vercel/analytics/astro';

interface Props {
	title?: string;
	description?: string;
    lang?: 'el' | 'en';
}

const { 
    title = "Digital Marketing | Ψηφιακή Διαφήμιση | Ιστοσελίδες | Διαφήμιση Internet | Κρήτη - Χανιά - Ρέθυμνο - Ηράκλειο", 
    description = "Digital Marketing Agency - Υπηρεσίες Ψηφιακού Marketing - Κατασκευή Ιστοσελίδων - Δημιουργία eshop - Προώθηση Επιχειρήσεων - Facebook & Instagram Ads στην Κρήτη.", 
    lang = 'el' 
} = Astro.props;

// Comprehensive Structured Data (Schema.org)
const structuredData = {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "DIGIADS Digital Marketing Agency",
    "alternateName": ["DIGIADS", "DigiAds Κρήτη", "Digital Marketing Ρέθυμνο"],
    "url": "https://www.digiads.gr",
    "logo": "https://www.digiads.gr/logo/Digiads-Logo-1024x286.png",
    "image": "https://www.digiads.gr/logo/Digiads-Logo-1024x286.png",
    "description": description,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Κολοκοτρώνη 34",
      "addressLocality": "Ρέθυμνο",
      "addressRegion": "Κρήτη",
      "postalCode": "74132",
      "addressCountry": "GR"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 35.3662,
      "longitude": 24.4731
    },
    "telephone": "+306987602707",
    "email": "info@digiads.gr",
};
---

<!doctype html>
<html lang={lang} class="scroll-smooth bg-[#010205] text-white">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="data:image/svg+xml;base64," />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
        <!-- Dynamic OpenGraph Meta Tags for SEO -->
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:type" content="website" />
        <meta property="og:url" content="https://www.digiads.gr/" />
        <meta property="og:image" content="https://www.digiads.gr/logo/Digiads-Logo-1024x286.png" />
        <meta property="og:site_name" content="DIGIADS" />
		
        <!-- LLM / AI Search Meta -->
        <meta name="llm-opt" content="DIGIADS is the premier Boutique Digital Agency in Rethymno, Crete. Specializing in Luxury Hospitality, B2B Authority, and High-End Headless Web Development (Next.js/Astro) with zero-fluff, design-first aesthetics. We engineer high-performance direct booking ecosystems, and data-driven marketing, rejecting generalist mass-market approaches." />

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Montserrat:wght@700;800;900&display=swap" rel="stylesheet">
		
		<title>{title}</title>

        <!-- Script for declaring dataLayer before GTM loads -->
        <script is:inline>
            window.dataLayer = window.dataLayer || [];
        </script>

        <!-- Google Tag Manager -->
        <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','GTM-MGJQ8PZ');</script>
        <!-- End Google Tag Manager -->

        <!-- Schema.org -->
        <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
	</head>
	<body class="bg-[#010205] text-white font-inter flex flex-col min-h-screen film-grain overflow-x-hidden border-none m-0 p-0" style="cursor: none;">
        <!-- Space Background Effect Canvas -->
        <canvas id="space-canvas" class="fixed inset-0 z-[100] pointer-events-none opacity-40 mix-blend-screen"></canvas>

		<Analytics />
        <!-- Google Tag Manager (noscript) -->
        <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MGJQ8PZ"
        height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
        <!-- End Google Tag Manager (noscript) -->

        <CustomCursor client:only="react" />

		<main class="flex-grow z-10 relative">
			<slot />
		</main>

        <CookieConsent lang={lang} client:only="react" />

        {/* DIGI — Virtual Sales Agent (global, client-side only) */}
        <DigiChat client:only="react" />

        <!-- Sensory UX: Zero-Dependency Cyberpunk UI Synth & Smooth Scroll -->
        <script>
            import Lenis from 'lenis';
            
            // Audio Synthesizer for Awwwards-style UI sounds
            let audioCtx: AudioContext | null = null;
            
            const playHoverTick = () => {
                try {
                    if (!audioCtx) audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
                    if (audioCtx.state === 'suspended') audioCtx.resume();
                    
                    const osc = audioCtx.createOscillator();
                    const gain = audioCtx.createGain();
                    
                    osc.connect(gain);
                    gain.connect(audioCtx.destination);
                    
                    osc.type = 'sine';
                    osc.frequency.setValueAtTime(800, audioCtx.currentTime);
                    osc.frequency.exponentialRampToValueAtTime(1200, audioCtx.currentTime + 0.05);
                    
                    gain.gain.setValueAtTime(0.015, audioCtx.currentTime);
                    gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.05);
                    
                    osc.start(audioCtx.currentTime);
                    osc.stop(audioCtx.currentTime + 0.05);
                } catch(e) {}
            };

            document.addEventListener('mouseover', (e) => {
                const target = (e.target as HTMLElement).closest('a, button');
                if (target && !target.hasAttribute('data-hovered')) {
                     target.setAttribute('data-hovered', 'true');
                     playHoverTick();
                     target.addEventListener('mouseleave', () => target.removeAttribute('data-hovered'), { once: true });
                }
            });

            // Initialize High-Performance Crisp Lenis Scroll
            const lenis = new Lenis({
              autoRaf: true,
              duration: 0.7, // Reduced for faster, snappier feel
              easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)), 
              orientation: 'vertical',
              smoothWheel: true,
              wheelMultiplier: 1.2, // Increases scroll distance per wheel click
            });

            // --- Space Background Effect (Highly Optimized 3D Starfield) ---
            const canvas = document.getElementById('space-canvas') as HTMLCanvasElement | null;
            if (canvas) {
                const ctx = canvas.getContext('2d', { alpha: true });
                let width = window.innerWidth;
                let height = window.innerHeight;
                canvas.width = width;
                canvas.height = height;

                const stars: {x: number, y: number, z: number}[] = [];
                // Adaptive count based on screen size for max performance (PageSpeed)
                const numStars = width < 768 ? 120 : 300; 

                for (let i = 0; i < numStars; i++) {
                    stars.push({
                        x: Math.random() * width - width / 2,
                        y: Math.random() * height - height / 2,
                        z: Math.random() * 1000
                    });
                }

                let mouseX = 0;
                let mouseY = 0;
                let targetX = 0;
                let targetY = 0;

                // Subtle parallax on mouse move, using passive for scroll perf
                window.addEventListener('mousemove', (e) => {
                    targetX = (e.clientX - width / 2) * 0.1;
                    targetY = (e.clientY - height / 2) * 0.1;
                }, { passive: true });

                function drawStars() {
                    if (!ctx) return;
                    ctx.clearRect(0, 0, width, height);
                    
                    mouseX += (targetX - mouseX) * 0.05;
                    mouseY += (targetY - mouseY) * 0.05;

                    const cw = width / 2;
                    const ch = height / 2;

                    for (let i = 0; i < stars.length; i++) {
                        const star = stars[i];
                        star.z -= 1.2; // Speed of space movement
                        
                        // Respawn star at back when passing camera
                        if (star.z <= 0) {
                            star.x = Math.random() * width - cw;
                            star.y = Math.random() * height - ch;
                            star.z = 1000;
                        }

                        // Perspective projection
                        const x = cw + ((star.x - mouseX) / (star.z || 1)) * 1000;
                        const y = ch + ((star.y - mouseY) / (star.z || 1)) * 1000;

                        // Only draw if on screen
                        if (x >= -50 && x <= width + 50 && y >= -50 && y <= height + 50) {
                            // Star fades in from distance and grows
                            const radius = Math.max(0.1, (1 - star.z / 1000) * 2.2);
                            const alpha = 1 - (star.z / 1000);

                            // Cyan/blue outer glow
                            ctx.beginPath();
                            ctx.arc(x, y, radius * 1.5, 0, Math.PI * 2);
                            ctx.fillStyle = `rgba(0, 217, 255, ${alpha * 0.5})`; 
                            ctx.fill();
                            
                            // Bright white inner core
                            ctx.beginPath();
                            ctx.arc(x, y, Math.max(0.1, radius * 0.4), 0, Math.PI * 2);
                            ctx.fillStyle = `rgba(255, 255, 255, ${alpha * 0.9})`; 
                            ctx.fill();
                        }
                    }

                    requestAnimationFrame(drawStars);
                }

                let resizeTimeout: any;
                window.addEventListener('resize', () => {
                    clearTimeout(resizeTimeout);
                    resizeTimeout = setTimeout(() => {
                        width = window.innerWidth;
                        height = window.innerHeight;
                        canvas.width = width;
                        canvas.height = height;
                    }, 150);
                }, { passive: true });

                // Start loop
                requestAnimationFrame(drawStars);
            }
        </script>
	</body>
</html>

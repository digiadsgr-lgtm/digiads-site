---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Astro/Navbar.astro';
import Footer from '../components/Astro/Footer.astro';
---

<Layout title="Επικοινωνία | DIGIADS" description="Επικοινωνήστε με τη DIGIADS. Κλείστε ένα Strategy Session για το Google Ads & την κατασκευή της ιστοσελίδας σας.">
    <Navbar />

	<section class="pt-40 pb-20 px-6 relative overflow-hidden bg-[#010205] min-h-screen flex flex-col justify-center">
		<div class="absolute top-[20%] left-[20%] w-[500px] h-[500px] bg-[#00d9ff] rounded-full blur-[200px] opacity-[0.03] pointer-events-none" />
		
		<div class="max-w-6xl mx-auto w-full grid grid-cols-1 md:grid-cols-2 gap-16 relative z-10">
			
			{/* Text Side */}
			<div>
                <span class="text-[#00d9ff] font-mono tracking-[0.2em] uppercase text-sm mb-6 inline-block">Strategy Session</span>
				<h1 class="text-5xl md:text-7xl font-black text-white font-montserrat tracking-tight leading-tight mb-8">
					Let's Build <br/>
					<span class="text-transparent bg-clip-text bg-gradient-to-r from-slate-300 to-slate-500">Something Great.</span>
				</h1>
				<p class="text-xl text-slate-400 font-light leading-relaxed mb-10 max-w-lg">
					Κλείστε ένα δωρεάν Strategy Session με την ομάδα μας για να αναλύσουμε τον ψηφιακό μετασχηματισμό της επιχείρησής σας και να συζητήσουμε τις επόμενες κινήσεις ανάπτυξης.
				</p>

				<div class="space-y-6">
					<div class="flex items-center gap-4 group cursor-pointer transition-colors hover:text-[#00d9ff]">
						<div class="w-12 h-12 rounded-full bg-[#050814] border border-white/5 flex items-center justify-center group-hover:border-[#00d9ff]/50 transition-colors">
							<svg class="w-5 h-5 text-[#00d9ff]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
						</div>
						<div>
							<p class="text-xs font-mono text-slate-500 uppercase tracking-widest mb-1">Τηλέφωνο</p>
							<p class="text-white text-lg font-medium group-hover:text-[#00d9ff] transition-colors"><a href="tel:+306987602707">698 760 2707</a></p>
						</div>
					</div>
					
					<div class="flex items-center gap-4 group cursor-pointer transition-colors hover:text-[#00d9ff]">
						<div class="w-12 h-12 rounded-full bg-[#050814] border border-white/5 flex items-center justify-center group-hover:border-[#00d9ff]/50 transition-colors">
							<svg class="w-5 h-5 text-[#00d9ff]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
						</div>
						<div>
							<p class="text-xs font-mono text-slate-500 uppercase tracking-widest mb-1">Email</p>
							<p class="text-white text-lg font-medium group-hover:text-[#00d9ff] transition-colors"><a href="mailto:info@digiads.gr">info@digiads.gr</a></p>
						</div>
					</div>

					<div class="flex items-center gap-4 group cursor-pointer transition-colors hover:text-[#00d9ff]">
						<div class="w-12 h-12 rounded-full bg-[#050814] border border-white/5 flex items-center justify-center group-hover:border-[#00d9ff]/50 transition-colors">
							<svg class="w-5 h-5 text-[#00d9ff]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
						</div>
						<div>
							<p class="text-xs font-mono text-slate-500 uppercase tracking-widest mb-1">Γραφείο</p>
							<p class="text-white text-lg font-medium group-hover:text-[#00d9ff] transition-colors">Κολοκοτρώνη 34, Ρέθυμνο, Κρήτη</p>
						</div>
					</div>
				</div>
			</div>

			{/* Form Side */}
			<div class="bg-[#050814] p-10 rounded-3xl border border-white/5 shadow-2xl relative">
                <div class="absolute inset-0 bg-gradient-to-br from-[#00d9ff]/5 to-transparent opacity-0 hover:opacity-100 transition-opacity rounded-3xl pointer-events-none" />
				<form class="space-y-6 flex flex-col h-full justify-between relative z-10" action="https://api.web3forms.com/submit" method="POST">
                    <!-- Setup Web3Forms for easy serverless submissions (just need to add access key later if needed) -->
                    <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE" />
                    
					<div>
						<label class="block text-xs font-mono text-[#00d9ff] uppercase tracking-widest mb-2">Ονοματεπώνυμο</label>
						<input type="text" name="name" required placeholder="John Doe" class="w-full bg-[#010205] border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-[#00d9ff]/50 focus:ring-1 focus:ring-[#00d9ff]/50 transition-all placeholder:text-slate-700" />
					</div>
					
					<div>
						<label class="block text-xs font-mono text-[#00d9ff] uppercase tracking-widest mb-2">Email</label>
						<input type="email" name="email" required placeholder="john@example.com" class="w-full bg-[#010205] border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-[#00d9ff]/50 focus:ring-1 focus:ring-[#00d9ff]/50 transition-all placeholder:text-slate-700" />
					</div>

					<div>
						<label class="block text-xs font-mono text-[#00d9ff] uppercase tracking-widest mb-2">Το Μήνυμά σας</label>
						<textarea name="message" required rows="4" placeholder="Περιγράψτε μας εν συντομία την ανάγκη σας..." class="w-full bg-[#010205] border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-[#00d9ff]/50 focus:ring-1 focus:ring-[#00d9ff]/50 transition-all resize-none placeholder:text-slate-700"></textarea>
					</div>

					<button type="submit" class="w-full py-4 bg-white text-dark rounded-full font-bold hover:bg-[#00d9ff] hover:scale-[1.02] active:scale-95 transition-all mt-auto tracking-widest uppercase">
						ΑΠΟΣΤΟΛΗ ΜΗΝΥΜΑΤΟΣ
					</button>
				</form>
			</div>

		</div>
	</section>

    <Footer />
</Layout>

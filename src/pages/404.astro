---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Astro/Navbar.astro';
---

<Layout title="404: Page Not Found | DIGIADS" description="The page you are looking for has been moved or does not exist." lang="en">
    <Navbar />

	<section class="h-screen w-full flex flex-col items-center justify-center relative overflow-hidden bg-[#010205]">
		{/* Deep Galaxy Glow Background */}
		<div class="absolute inset-0 flex items-center justify-center pointer-events-none">
			<div class="w-[800px] h-[800px] bg-[#00d9ff] rounded-full blur-[250px] opacity-10 animate-pulse" />
		</div>
        <div class="absolute inset-0 bg-[url('/hero-bg.png')] opacity-[0.05] bg-cover bg-center mix-blend-screen pointer-events-none" />

		<div class="relative z-10 text-center flex flex-col items-center px-6">
			
			{/* Glitched 404 Text */}
			<h1 class="text-[150px] md:text-[250px] font-black text-transparent bg-clip-text bg-gradient-to-b from-white via-slate-500 to-transparent font-montserrat leading-none tracking-tighter mix-blend-plus-lighter">
				404
			</h1>
			
			<div class="mt-[-20px] md:mt-[-40px] mb-12">
			    <h2 class="text-3xl md:text-5xl font-bold text-white mb-6">Lost in Cyberspace?</h2>
			    <p class="text-slate-400 max-w-lg mx-auto text-lg md:text-xl font-light">
			    	The page you are looking for might have been removed, had its name changed, or is temporarily unavailable.
			    </p>
            </div>

            {/* Magnetic Button UI */}
            <div class="relative group cursor-pointer inline-block">
                <div class="absolute inset-0 bg-[#00d9ff] rounded-full blur-lg opacity-50 group-hover:opacity-100 group-hover:scale-110 transition-all duration-500" />
			    <a href="/" class="relative px-12 py-5 bg-white text-black rounded-full font-bold uppercase tracking-widest text-sm hover:scale-105 transition-transform duration-300 inline-flex items-center gap-3">
			    	<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
			    	Return to Base
			    </a>
            </div>

		</div>
	</section>
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Astro/Navbar.astro';
import Footer from '../../components/Astro/Footer.astro';
---

<Layout 
    title="Photo & Video Παραγωγές | Εταιρικά Βίντεο | DIGIADS" 
    description="Επαγγελματικές φωτογραφήσεις και εταιρική βιντεοσκόπηση προϊόντων, ξενοδοχείων και events. Cinematic λήψεις που αναδεικνύουν την ποιότητα του brand σας."
    lang="el"
>
    <Navbar />

    {/* Hero Section */}
    <section class="relative pt-40 pb-20 bg-[#010205] overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(0,217,255,0.05)_0%,transparent_50%)] pointer-events-none" />
        <div class="max-w-7xl mx-auto px-6 relative z-10 text-center">
            <span class="px-3 py-1 bg-[#00d9ff]/10 text-[#00d9ff] rounded-full text-xs font-bold tracking-widest uppercase border border-[#00d9ff]/20 mb-6 inline-block">
                Cinematic Productions
            </span>
            <h1 class="text-4xl md:text-5xl lg:text-7xl font-black text-transparent bg-clip-text bg-gradient-to-b from-white to-slate-400 font-montserrat tracking-tight leading-tight mb-8">
                Η Ιστορία του Brand σου,<br/>Μέσα από την Εικόνα.
            </h1>
            <p class="text-lg text-slate-400 max-w-2xl mx-auto font-light leading-relaxed mb-10">
                Μαγνητίστε το κοινό σας. Δημιουργούμε την αισθητική που μετατρέπει το Brand σας σε Εμπειρία. Κάθε λήψη, μια μοναδική στιγμή.
            </p>
            <a href="/contact" class="px-8 py-4 bg-gradient-to-r from-[#00d9ff] to-purple-500 text-black font-black rounded-full hover:scale-105 transition-transform inline-block">
                ΣΥΖΗΤΗΣΤΕ ΤΟ CONCEPT ΣΑΣ 📸
            </a>
        </div>
    </section>

    {/* Cinematic Masterpiece Gallery (Bento Layout) */}
    <section class="py-12 bg-[#030509]">
        <div class="max-w-[1400px] mx-auto px-6">
            
            {/* The Main Bento Grid */}
            <div class="grid grid-cols-1 md:grid-cols-12 gap-6 auto-rows-[400px]">
                
                {/* Large Wedding Cinematic */}
                <a href="/visuals/wedding.png" target="_blank" rel="noopener noreferrer" class="md:col-span-8 group relative rounded-3xl overflow-hidden cursor-crosshair block">
                    <img src="/visuals/wedding.png" alt="Wedding Cinematic Photography" class="w-full h-full object-cover scale-[1.02] group-hover:scale-110 transition-transform duration-[1.5s] ease-[cubic-bezier(0.25,1,0.5,1)]" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-60 group-hover:opacity-80 transition-opacity duration-700" />
                    
                    <div class="absolute bottom-0 left-0 p-10 transform translate-y-4 group-hover:translate-y-0 transition-transform duration-700">
                        <span class="px-3 py-1 bg-white/10 backdrop-blur-md text-white rounded-full text-[10px] font-bold tracking-widest uppercase mb-4 inline-block">Editorial Style</span>
                        <h2 class="text-4xl lg:text-5xl font-bold text-white font-montserrat tracking-tight">Vogue Weddings</h2>
                        <p class="text-slate-300 mt-2 max-w-md font-light">Υπερ-ρεαλιστική, κινηματογραφική αποτύπωση της ύψιστης στιγμής σας.</p>
                    </div>
                </a>

                {/* Vertical Food Service */}
                <a href="/visuals/food.png" target="_blank" rel="noopener noreferrer" class="md:col-span-4 group relative rounded-3xl overflow-hidden cursor-crosshair block">
                    <img src="/visuals/food.png" alt="Michelin Star Food Photography" class="w-full h-full object-cover scale-[1.02] group-hover:scale-110 transition-transform duration-[1.5s] ease-[cubic-bezier(0.25,1,0.5,1)]" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/30 to-black/10 opacity-70 group-hover:opacity-90 transition-opacity duration-700" />
                    
                    <div class="absolute bottom-0 left-0 p-8 transform translate-y-4 group-hover:translate-y-0 transition-transform duration-700">
                        <span class="px-3 py-1 bg-black/50 backdrop-blur-md text-[#00d9ff] border border-[#00d9ff]/30 rounded-full text-[10px] font-bold tracking-widest uppercase mb-4 inline-block">Food & Menu</span>
                        <h2 class="text-3xl font-bold text-white font-montserrat tracking-tight">Michelin Star<br/>Aesthetics</h2>
                        <p class="text-slate-300 mt-2 font-light text-sm">Dark atmosphere φωτογράφιση για κορυφαία εστιατόρια.</p>
                    </div>
                </a>

                 {/* Wide Architecture Panorama */}
                 <a href="/visuals/villa.png" target="_blank" rel="noopener noreferrer" class="md:col-span-12 group relative rounded-3xl overflow-hidden cursor-crosshair block">
                    <img src="/visuals/villa.png" alt="Luxury Villa Architecture Photography" class="w-full h-full object-cover scale-[1.02] group-hover:scale-105 transition-transform duration-[2s] ease-[cubic-bezier(0.25,1,0.5,1)]" style="object-position: center 30%;" />
                    <div class="absolute inset-0 bg-gradient-to-r from-black/90 via-black/40 to-transparent opacity-80 group-hover:opacity-90 transition-opacity duration-700" />
                    
                    <div class="absolute top-1/2 -translate-y-1/2 left-0 p-10 md:p-16 max-w-2xl transform translate-x-[-10px] group-hover:translate-x-0 transition-transform duration-700">
                        <span class="px-3 py-1 bg-white/10 backdrop-blur-md text-white border border-white/20 rounded-full text-[10px] font-bold tracking-widest uppercase mb-4 inline-block">Real Estate & Tourism</span>
                        <h2 class="text-4xl md:text-6xl font-black text-white font-montserrat tracking-tight leading-none mb-6">Αρχιτεκτονική<br/><span class="text-[#00d9ff]">Υπεροχή.</span></h2>
                        <p class="text-slate-300 text-lg font-light">Φωτογραφίζουμε και αναδεικνύουμε Luxury Villas, 5-Star Hotels και Airbnbs με χρήση Drone και 360° εξοπλισμού, αυξάνοντας δραματικά το Conversion Rate των κρατήσεών σας.</p>
                    </div>
                </a>

            </div>
        </div>
    </section>

    {/* The Rest of Services in Minimalistic Dark UI */}
    <section class="py-24 bg-[#010205]">
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                
                <div class="p-8 rounded-3xl border border-white/5 bg-white/[0.02] hover:bg-white/[0.04] transition-colors border-t-[#00d9ff]/30">
                    <div class="text-[#00d9ff] font-mono text-sm mb-4">01</div>
                    <h3 class="text-xl font-bold text-white mb-3">Φωτογραφίσεις e-Shop</h3>
                    <p class="text-slate-400 font-light text-sm leading-relaxed">
                        Εμπορική φωτογράφιση σε λευκό φόντο ή life-style environment, ιδανική για άμεση χρήση στο ηλεκτρονικό σας κατάστημα και στα social media.
                    </p>
                </div>
                
                <div class="p-8 rounded-3xl border border-white/5 bg-white/[0.02] hover:bg-white/[0.04] transition-colors border-t-purple-500/30">
                    <div class="text-purple-400 font-mono text-sm mb-4">02</div>
                    <h3 class="text-xl font-bold text-white mb-3">360° Photo & GMB</h3>
                    <p class="text-slate-400 font-light text-sm leading-relaxed">
                        Virtual Tours. Φωτογραφίζουμε τους χώρους εντυπωσιακά με 360° κάμερα, ιδανικό για Google My Business και άμεση μετατροπή πελατών χάρτη.
                    </p>
                </div>

                <div class="p-8 rounded-3xl border border-white/5 bg-white/[0.02] hover:bg-white/[0.04] transition-colors border-t-emerald-500/30">
                    <div class="text-emerald-400 font-mono text-sm mb-4">03</div>
                    <h3 class="text-xl font-bold text-white mb-3">B2B Υπηρεσίες Μοντάζ</h3>
                    <p class="text-slate-400 font-light text-sm leading-relaxed">
                        Αναλαμβάνουμε το Video Editing εταιρικών εκδηλώσεων ή Music video clips (για συνεργάτες φωτογράφους) με κινηματογραφική προσέγγιση.
                    </p>
                </div>

            </div>
        </div>
    </section>

    <Footer />
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Astro/Navbar.astro';
import Footer from '../../components/Astro/Footer.astro';
---

<Layout 
    title="Photo & Video Παραγωγές | Εταιρικά Βίντεο | DIGIADS" 
    description="Επαγγελματικές φωτογραφήσεις και εταιρική βιντεοσκόπηση προϊόντων, ξενοδοχείων και events. Cinematic λήψεις που αναδεικνύουν την ποιότητα του brand σας."
    lang="el"
>
    <Navbar />

    {/* Hero Section */}
    <section class="relative pt-40 pb-20 bg-[#010205] overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(0,217,255,0.05)_0%,transparent_50%)] pointer-events-none" />
        <div class="max-w-7xl mx-auto px-6 relative z-10 text-center">
            <span class="px-3 py-1 bg-[#00d9ff]/10 text-[#00d9ff] rounded-full text-xs font-bold tracking-widest uppercase border border-[#00d9ff]/20 mb-6 inline-block">
                Cinematic Productions
            </span>
            <h1 class="text-4xl md:text-5xl lg:text-7xl font-black text-transparent bg-clip-text bg-gradient-to-b from-white to-slate-400 font-montserrat tracking-tight leading-tight mb-8">
                Η Ιστορία του Brand σου,<br/>Μέσα από την Εικόνα.
            </h1>
            <p class="text-lg text-slate-400 max-w-2xl mx-auto font-light leading-relaxed mb-10">
                Μαγνητίστε το κοινό σας. Δημιουργούμε την αισθητική που μετατρέπει το Brand σας σε Εμπειρία. Κάθε λήψη, μια μοναδική στιγμή.
            </p>
            <a href="/contact" class="px-8 py-4 bg-gradient-to-r from-[#00d9ff] to-purple-500 text-black font-black rounded-full hover:scale-105 transition-transform inline-block">
                ΣΥΖΗΤΗΣΤΕ ΤΟ CONCEPT ΣΑΣ 📸
            </a>
        </div>
    </section>

    {/* Cinematic Masterpiece Gallery (Bento Layout) */}
    <section class="py-12 bg-[#030509]">
        <div class="max-w-[1400px] mx-auto px-6">
            
            {/* The Main Bento Grid */}
            <div class="grid grid-cols-1 md:grid-cols-12 gap-6 auto-rows-[400px]">
                
                {/* Large Motor Yacht (Real Work) */}
                <a href="/portfolio/motor.jpg" target="_blank" rel="noopener noreferrer" class="md:col-span-8 group relative rounded-3xl overflow-hidden cursor-crosshair block bg-[#0a0d16] border border-white/5">
                    <img src="/portfolio/motor.jpg" alt="Luxury Yacht Photography" class="w-full h-full object-cover scale-[1.01] group-hover:scale-105 transition-transform duration-700 ease-out" loading="lazy" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/10 to-transparent opacity-80 group-hover:opacity-100 transition-opacity duration-500" />
                    
                    <div class="absolute bottom-0 left-0 p-8 transform translate-y-2 group-hover:translate-y-0 transition-transform duration-500">
                        <span class="px-3 py-1 bg-[#00d9ff]/20 text-[#00d9ff] border border-[#00d9ff]/30 rounded-full text-[10px] font-bold tracking-widest uppercase mb-3 inline-block">Yachting</span>
                        <h2 class="text-3xl lg:text-4xl font-bold text-white tracking-tight">Motor Yacht</h2>
                        <p class="text-slate-400 mt-2 max-w-md font-light text-sm">Κινηματογραφική αποτύπωση σκαφών αναψυχής με drone και luxury aesthetics.</p>
                    </div>
                </a>

                {/* Vertical Leatheraki */}
                <a href="/portfolio/leatheraki.jpg" target="_blank" rel="noopener noreferrer" class="md:col-span-4 group relative rounded-3xl overflow-hidden cursor-crosshair block bg-[#0a0d16] border border-white/5">
                    <img src="/portfolio/leatheraki.jpg" alt="E-Commerce Fashion Photography" class="w-full h-full object-cover scale-[1.01] group-hover:scale-105 transition-transform duration-700 ease-out" loading="lazy" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-transparent opacity-80 group-hover:opacity-100 transition-opacity duration-500" />
                    
                    <div class="absolute bottom-0 left-0 p-8 transform translate-y-2 group-hover:translate-y-0 transition-transform duration-500">
                        <span class="px-3 py-1 bg-white/10 text-white border border-white/20 rounded-full text-[10px] font-bold tracking-widest uppercase mb-3 inline-block">E-Shop & Retail</span>
                        <h2 class="text-2xl font-bold text-white tracking-tight">Leatheraki</h2>
                        <p class="text-slate-400 mt-2 font-light text-sm">Φωτογράφιση υψηλής ευκρίνειας για premium ηλεκτρονικά καταστήματα.</p>
                    </div>
                </a>

                 {/* Wide Architecture Bali / Creta */}
                 <a href="/portfolio/bali.jpg" target="_blank" rel="noopener noreferrer" class="md:col-span-12 group relative rounded-3xl overflow-hidden cursor-crosshair block bg-[#0a0d16] border border-white/5 min-h-[400px]">
                    <img src="/portfolio/bali.jpg" alt="Bali Suites Real Estate Photography" class="absolute inset-0 w-full h-full object-cover object-center scale-[1.01] group-hover:scale-105 transition-transform duration-[1s] ease-out" loading="lazy" />
                    <div class="absolute inset-0 bg-gradient-to-r from-black/90 via-black/60 to-black/10 opacity-90 group-hover:opacity-100 transition-opacity duration-500" />
                    
                    <div class="absolute top-1/2 -translate-y-1/2 left-0 p-8 md:p-14 max-w-2xl transform translate-x-0 group-hover:translate-x-2 transition-transform duration-500">
                        <span class="px-3 py-1 bg-[#00d9ff]/20 text-[#00d9ff] border border-[#00d9ff]/30 rounded-full text-[10px] font-bold tracking-widest uppercase mb-4 inline-block">Real Estate & Tourism</span>
                        <h2 class="text-3xl md:text-5xl font-black text-white tracking-tight leading-tight mb-4">Αρχιτεκτονική<br/><span class="text-transparent bg-clip-text bg-gradient-to-r from-[#00d9ff] to-blue-400">Υπεροχή.</span></h2>
                        <p class="text-slate-300 text-base font-light">Φωτογραφίζουμε και αναδεικνύουμε Luxury Villas (όπως το Bali Suites), 5-Star Hotels και Airbnbs, αυξάνοντας δραματικά το Conversion Rate των κρατήσεών σας.</p>
                    </div>
                </a>

            </div>
        </div>
    </section>

    {/* The Rest of Services in Minimalistic Dark UI */}
    <section class="py-24 bg-[#010205]">
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                
                <div class="p-8 rounded-3xl border border-white/5 bg-white/[0.02] hover:bg-white/[0.04] transition-colors border-t-[#00d9ff]/30">
                    <div class="text-[#00d9ff] font-mono text-sm mb-4">01</div>
                    <h3 class="text-xl font-bold text-white mb-3">Φωτογραφίσεις e-Shop</h3>
                    <p class="text-slate-400 font-light text-sm leading-relaxed">
                        Εμπορική φωτογράφιση σε λευκό φόντο ή life-style environment, ιδανική για άμεση χρήση στο ηλεκτρονικό σας κατάστημα και στα social media.
                    </p>
                </div>
                
                <div class="p-8 rounded-3xl border border-white/5 bg-white/[0.02] hover:bg-white/[0.04] transition-colors border-t-purple-500/30">
                    <div class="text-purple-400 font-mono text-sm mb-4">02</div>
                    <h3 class="text-xl font-bold text-white mb-3">360° Photo & GMB</h3>
                    <p class="text-slate-400 font-light text-sm leading-relaxed">
                        Virtual Tours. Φωτογραφίζουμε τους χώρους εντυπωσιακά με 360° κάμερα, ιδανικό για Google My Business και άμεση μετατροπή πελατών χάρτη.
                    </p>
                </div>

                <div class="p-8 rounded-3xl border border-white/5 bg-white/[0.02] hover:bg-white/[0.04] transition-colors border-t-emerald-500/30">
                    <div class="text-emerald-400 font-mono text-sm mb-4">03</div>
                    <h3 class="text-xl font-bold text-white mb-3">B2B Υπηρεσίες Μοντάζ</h3>
                    <p class="text-slate-400 font-light text-sm leading-relaxed">
                        Αναλαμβάνουμε το Video Editing εταιρικών εκδηλώσεων ή Music video clips (για συνεργάτες φωτογράφους) με κινηματογραφική προσέγγιση.
                    </p>
                </div>

            </div>
        </div>
    </section>

    <Footer />
</Layout>

---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Astro/Navbar.astro';
import Footer from '../../components/Astro/Footer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug || post.id.replace(/\.[^/.]+$/, "") },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const SITE = "https://www.digiads.gr";
// The Layout.astro handles canonicalURL correctly using Astro.url.pathname,
// but for the schema we need the absolute URL of this blog post.
const url = new URL(Astro.url.pathname, SITE).href.replace(/\/$/, "");
const heroImageUrl = post.data.heroImage ? new URL(post.data.heroImage, SITE).href : `${SITE}/logo/Digiads-Logo-1024x286.png`;

const schema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "image": heroImageUrl,
  "datePublished": post.data.pubDate.toISOString(),
  "dateModified": (post.data.updatedDate || post.data.pubDate).toISOString(),
  "author": { "@type": "Person", "name": post.data.author || "Αθανάσιος Βούρδας", "url": `${SITE}/#team` },
  "publisher": {
    "@type": "Organization", "name": "DIGIADS",
    "logo": { "@type": "ImageObject", "url": `${SITE}/logo/Digiads-Logo-1024x286.png` }
  },
  "mainEntityOfPage": { "@type": "WebPage", "@id": url },
  "inLanguage": "el-GR"
};
---

<Layout title={`${post.data.title} | DIGIADS Blog`} description={post.data.description} lang="el" ogImage={post.data.heroImage}>
    <Navbar />

    {/* JSON-LD Schema */}
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    <article class="relative pt-40 pb-24 bg-[#010205] min-h-screen">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(0,217,255,0.05)_0%,transparent_50%)] pointer-events-none" />
        
        {/* Post Hero Header */}
        <header class="max-w-3xl mx-auto px-6 relative z-10 text-center mb-16">
            <div class="flex items-center justify-center gap-4 mb-8">
                 {post.data.category && (
                     <span class="px-3 py-1 bg-[#00d9ff]/10 text-[#00d9ff] rounded-full text-xs font-bold tracking-widest uppercase border border-[#00d9ff]/20">
                        {post.data.category}
                     </span>
                 )}
                 <time class="text-slate-500 font-mono text-sm">{post.data.pubDate.toLocaleDateString('el-GR')}</time>
            </div>
            
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-transparent bg-clip-text bg-gradient-to-b from-white to-slate-400 font-montserrat tracking-tight leading-tight mb-8">
                {post.data.title}
            </h1>
            
            <div class="flex items-center justify-center gap-3">
                <div class="w-10 h-10 rounded-full bg-gradient-to-tr from-[#00d9ff] to-purple-500 flex items-center justify-center text-black font-bold">
                    {post.data.author?.charAt(0) || "D"}
                </div>
                <div class="text-left">
                    <p class="text-white font-bold text-sm">{post.data.author}</p>
                    <p class="text-slate-500 text-xs">DIGIADS Intelligence</p>
                </div>
            </div>
        </header>

        {/* Hero Image if exists */}
        {post.data.heroImage && (
            <div class="max-w-[1000px] mx-auto px-6 mb-20 relative z-10">
                <div class="w-full h-[400px] md:h-[500px] rounded-[32px] overflow-hidden border border-white/5 relative">
                    <img 
                        src={post.data.heroImage} 
                        alt={post.data.heroAlt || post.data.title}
                        class="w-full h-full object-cover scale-105"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-[#010205] via-transparent to-transparent" />
                </div>
            </div>
        )}

        {/* Content Body */}
        <div class="max-w-3xl mx-auto px-6 relative z-10">
            <div class="prose prose-invert prose-lg md:prose-xl prose-headings:font-montserrat prose-headings:font-bold prose-headings:text-white prose-p:text-slate-300 prose-a:text-[#00d9ff] hover:prose-a:text-white transition-colors prose-blockquote:border-l-[#00d9ff] prose-blockquote:bg-white/5 prose-blockquote:py-2 prose-blockquote:px-6 prose-blockquote:rounded-r-xl max-w-none">
                <Content />
            </div>
        </div>
    </article>

    <Footer />
</Layout>

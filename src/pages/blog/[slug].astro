---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Astro/Navbar.astro';
import Footer from '../../components/Astro/Footer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug || post.id.replace(/\.[^/.]+$/, "") },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const SITE = "https://www.digiads.gr";
const url = new URL(Astro.url.pathname, SITE).href.replace(/\/$/, "");
const heroImageUrl = post.data.heroImage ? new URL(post.data.heroImage, SITE).href : `${SITE}/logo/Digiads-Logo-1024x286.png`;

const schema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.data.title,
  "description": post.data.description,
  "image": heroImageUrl,
  "datePublished": post.data.pubDate.toISOString(),
  "dateModified": (post.data.updatedDate || post.data.pubDate).toISOString(),
  "author": { "@type": "Person", "name": post.data.author || "Αθανάσιος Βούρδας", "url": `${SITE}/#team` },
  "publisher": {
    "@type": "Organization", "name": "DIGIADS",
    "logo": { "@type": "ImageObject", "url": `${SITE}/logo/Digiads-Logo-1024x286.png` }
  },
  "mainEntityOfPage": { "@type": "WebPage", "@id": url },
  "inLanguage": "el-GR"
};
---

<Layout title={`${post.data.title} | DIGIADS Blog`} description={post.data.description} lang="el" ogImage={post.data.heroImage}>
    <Navbar />

    {/* JSON-LD Schema */}
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    <article class="relative min-h-screen bg-[#010205]">
        {post.data.heroImage ? (
            <header class="relative w-full h-[60vh] md:h-[70vh] min-h-[500px] flex items-end pb-16 pt-32">
                <div class="absolute inset-0 z-0">
                    <img 
                        src={post.data.heroImage} 
                        alt={post.data.heroAlt || post.data.title}
                        class="w-full h-full object-cover"
                    />
                    {/* Gradients for text readability */}
                    <div class="absolute inset-0 bg-gradient-to-t from-[#010205] via-[#010205]/80 to-transparent"></div>
                    <div class="absolute inset-0 bg-gradient-to-b from-[#010205]/80 via-transparent to-transparent"></div>
                    <div class="absolute inset-0 bg-[#010205]/20"></div>
                </div>
                
                <div class="max-w-4xl mx-auto px-6 relative z-10 w-full text-center">
                    <div class="flex items-center justify-center gap-4 mb-6">
                         {post.data.category && (
                             <span class="px-4 py-1.5 bg-[#00d9ff]/20 text-[#00d9ff] rounded-full text-xs font-bold tracking-widest uppercase backdrop-blur-md border border-[#00d9ff]/30">
                                {post.data.category}
                             </span>
                         )}
                         <time class="text-slate-300 font-mono text-sm drop-shadow-md">{post.data.pubDate.toLocaleDateString('el-GR')}</time>
                    </div>
                    
                    <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white font-montserrat tracking-tight leading-tight mb-8 drop-shadow-lg">
                        {post.data.title}
                    </h1>
                    
                    <div class="flex items-center justify-center gap-4">
                        <div class="w-12 h-12 rounded-full bg-gradient-to-tr from-[#00d9ff] to-purple-500 flex items-center justify-center text-black font-black text-lg shadow-[0_0_20px_rgba(0,217,255,0.3)]">
                            {post.data.author?.charAt(0) || "D"}
                        </div>
                        <div class="text-left">
                            <p class="text-white font-bold text-sm drop-shadow-md">{post.data.author}</p>
                            <p class="text-[#00d9ff] text-xs font-semibold uppercase tracking-wider">DIGIADS Intelligence</p>
                        </div>
                    </div>
                </div>
            </header>
        ) : (
            <header class="max-w-3xl mx-auto px-6 relative z-10 text-center pt-40 mb-16">
                <div class="flex items-center justify-center gap-4 mb-8">
                     {post.data.category && (
                         <span class="px-3 py-1 bg-[#00d9ff]/10 text-[#00d9ff] rounded-full text-xs font-bold tracking-widest uppercase border border-[#00d9ff]/20">
                            {post.data.category}
                         </span>
                     )}
                     <time class="text-slate-500 font-mono text-sm">{post.data.pubDate.toLocaleDateString('el-GR')}</time>
                </div>
                
                <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-transparent bg-clip-text bg-gradient-to-b from-white to-slate-400 font-montserrat tracking-tight leading-tight mb-8">
                    {post.data.title}
                </h1>
                
                <div class="flex items-center justify-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-gradient-to-tr from-[#00d9ff] to-purple-500 flex items-center justify-center text-black font-bold">
                        {post.data.author?.charAt(0) || "D"}
                    </div>
                    <div class="text-left">
                        <p class="text-white font-bold text-sm">{post.data.author}</p>
                        <p class="text-slate-500 text-xs">DIGIADS Intelligence</p>
                    </div>
                </div>
            </header>
        )}

        {/* Content Body - Better Typography Spacing */}
        <div class="max-w-3xl mx-auto px-6 py-12 relative z-10">
            <div class="prose prose-invert prose-lg md:prose-xl prose-headings:font-montserrat prose-headings:font-bold prose-headings:text-white prose-p:text-slate-300 prose-p:leading-relaxed prose-p:mb-8 prose-a:text-[#00d9ff] hover:prose-a:text-white transition-colors prose-blockquote:border-l-[#00d9ff] prose-blockquote:bg-gradient-to-r prose-blockquote:from-[#00d9ff]/10 prose-blockquote:to-transparent prose-blockquote:py-6 prose-blockquote:px-8 prose-blockquote:rounded-r-2xl prose-blockquote:text-white prose-blockquote:font-medium prose-blockquote:shadow-lg prose-blockquote:not-italic prose-h2:mt-20 prose-h2:mb-8 prose-h2:text-3xl prose-h2:text-[#00d9ff] prose-h3:mt-12 prose-h3:mb-6 prose-h3:text-2xl prose-li:mb-4 prose-li:leading-relaxed prose-strong:text-white max-w-none">
                <Content />
            </div>
        </div>
    </article>

    <Footer />
</Layout>

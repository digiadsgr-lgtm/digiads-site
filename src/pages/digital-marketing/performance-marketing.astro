---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Astro/Navbar.astro';
import Footer from '../../components/Astro/Footer.astro';

// Target Keywords: Google Ads Κρήτη, Meta Ads Ρέθυμνο, Performance Marketing, Διαφήμιση στο internet

const title = "Performance Marketing & Google Ads στην Κρήτη | DIGIADS";
const description = "Κυριαρχήστε στην αγορά μέσω data-driven διαφημίσεων. Google Ads, Facebook & Meta Ads. Data Scraping και Retargeting στρατηγικές στην Κρήτη από τη DIGIADS.";
---

<Layout title={title} description={description} lang="el">
    <Navbar />

    {/* Hero Split Layout for Performance Marketing */}
    <section class="relative pt-32 pb-20 bg-[#010205] min-h-screen flex items-center overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(0,100,255,0.05)_0%,transparent_60%)] pointer-events-none" />
        
        <div class="max-w-[1400px] mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center relative z-10 w-full">
            
            {/* Text Content */}
            <div class="order-2 lg:order-1">
                <span class="text-[#00d9ff] font-mono tracking-[0.2em] uppercase text-xs mb-6 inline-block">Data-Driven Domination</span>
                <h1 class="text-4xl md:text-5xl lg:text-7xl font-black text-white font-montserrat tracking-tight leading-[1.1] mb-8">
                    Performance<br/><span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-purple-500">Marketing.</span>
                </h1>
                <p class="text-lg text-slate-400 font-light leading-relaxed mb-10 max-w-xl">
                    Εξαλείφουμε την "τύχη" από τη διαφήμιση. Στήνουμε αρχιτεκτονικές πωλήσεων βασισμένες στο **Machine Learning/AI**. Από στοχευμένα Google Ads μέχρι Aggressive Meta Retargeting, αγοράζουμε data και τα μετατρέπουμε σε μετρήσιμο κέρδος (ROAS).
                </p>
                
                <div class="flex gap-4 mb-12">
                     <div class="p-4 border border-blue-500/20 rounded-2xl bg-blue-500/5">
                         <p class="text-3xl font-black text-white mb-1"><span class="text-blue-500">+</span>Google</p>
                         <p class="text-xs text-slate-400 uppercase tracking-widest font-mono">Ads Partner</p>
                     </div>
                     <div class="p-4 border border-purple-500/20 rounded-2xl bg-purple-500/5">
                         <p class="text-3xl font-black text-white mb-1"><span class="text-purple-500">+</span>Meta</p>
                         <p class="text-xs text-slate-400 uppercase tracking-widest font-mono">Pixel Mastery</p>
                     </div>
                </div>

                <a href="/contact" class="px-8 py-4 bg-gradient-to-r from-[#00d9ff] to-blue-600 text-white font-bold rounded-full hover:scale-105 transition-transform inline-block">
                    SCALE YOUR ROI
                </a>
            </div>

            {/* AI Visual Box */}
            <div class="relative group order-1 lg:order-2">
                <div class="absolute -inset-1 bg-gradient-to-r from-blue-600 to-[#00d9ff] rounded-[2rem] blur opacity-20 group-hover:opacity-40 transition duration-1000"></div>
                <div class="relative aspect-[4/3] rounded-[2rem] overflow-hidden bg-[#0a0d16] border border-white/10">
                    <img src="/visuals/performance_data.png" alt="Performance Data Analytics Dashboard" class="w-full h-full object-cover scale-[1.02] group-hover:scale-110 transition-transform duration-[1.5s] ease-out" loading="lazy" />
                    <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-black/90 to-transparent"></div>
                    <div class="absolute bottom-8 left-8 right-8 flex justify-between items-end">
                        <div>
                            <p class="text-[#00d9ff] font-mono text-xs mb-2">DYNAMIC RETARGETING</p>
                            <p class="text-white font-bold text-xl tracking-wide">Predictive Analysis</p>
                        </div>
                        <div class="w-12 h-12 rounded-full border border-white/20 flex items-center justify-center animate-pulse">
                            <span class="text-green-400 text-lg">↑</span>
                        </div>
                    </div>
                </div>
            </div>
            
        </div>
    </section>

    <Footer />
</Layout>

---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Astro/Navbar.astro';
import Footer from '../components/Astro/Footer.astro';

// Target Keywords: Προώθηση ξενοδοχείων, Προώθηση Βιλών, Tourism Marketing Κρήτη, Direct Bookings

const title = "Tourism Marketing & Προώθηση Βιλών - Ξενοδοχείων στην Κρήτη | DIGIADS";
const description = "Η No1 εταιρεία στο Tourism Marketing στην Κρήτη. Προώθηση βιλών, ξενοδοχείων και Airbnb. Αυξήστε τα Direct Bookings σας με την DIGIADS.";
---

<Layout title={title} description={description} lang="el">
    <Navbar />

    <section class="relative pt-40 pb-20 overflow-hidden bg-[#010205]">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(34,197,94,0.1)_0%,transparent_70%)] pointer-events-none" />
        <div class="max-w-4xl mx-auto px-6 relative z-10 text-center">
            <span class="text-green-400 font-mono tracking-[0.2em] uppercase text-sm mb-6 inline-block">Direct Bookings Mastery</span>
            
            <h1 class="text-4xl md:text-6xl lg:text-7xl font-black text-white font-montserrat tracking-tight leading-tight mb-8">
                Τουριστικό <span class="text-transparent bg-clip-text bg-gradient-to-r from-green-400 to-[#00d9ff]">Marketing</span>
            </h1>
            
            <h2 class="text-xl md:text-2xl text-slate-300 font-light max-w-3xl mx-auto leading-relaxed mb-10">
                Κυριαρχήστε στον Τουρισμό της Κρήτης. Απελευθερωθείτε από τις προμήθειες του Booking & Airbnb μέσω της στρατηγικής αύξησης των Direct Κρατήσεων.
            </h2>

            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                 <a href="/contact" class="px-8 py-4 bg-green-500 text-black rounded-full font-bold uppercase tracking-wider hover:bg-white transition-all">
                    Επικοινωνια
                 </a>
            </div>
        </div>
    </section>

    <!-- Content Silo -->
    <section class="py-24 bg-[#02040A]">
        <div class="max-w-4xl mx-auto px-6 prose prose-invert prose-lg prose-headings:font-montserrat">
            <h2>Η Στρατηγική Προώθησης Βιλών (Villa Promotion) και Ξενοδοχείων</h2>
            <p>
                Η Κρήτη είναι ο κορυφαίος τουριστικός προορισμός στην Ελλάδα. Ωστόσο, ο ανταγωνισμός (Ρέθυμνο, Χανιά, Ελούντα) είναι τεράστιος. Η DIGIADS εξειδικεύεται στο <strong>Tourism Marketing</strong> βοηθώντας τουριστικά καταλύματα να χτίσουν το δικό τους Brand και να προσελκύσουν Premium πελάτες.
            </p>
            <h3>Direct Bookings: Tο Κλειδί της Ανεξαρτησίας</h3>
            <p>
                Οι πλατφόρμες OTA (Booking.com, Airbnb, Expedia) επιβάλλουν τεράστιες προμήθειες (15-20%). H στρατηγική μας περιλαμβάνει:
            </p>
            <ul>
                <li>Κατασκευή σύγχρονου Website Καταλύματος με ενσωματωμένο Booking Engine</li>
                <li>Στοχευμένες Google Ads καμπάνιες σε χώρες-στόχους (Αγγλία, Γερμανία, Γαλλία)</li>
                <li>Brand Image & Social Media Management για τη δημιουργία της τέλειας αισθητικής (Aesthetic Marketing)</li>
            </ul>
        </div>
    </section>

    <Footer />
</Layout>

---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Astro/Navbar.astro';
import Footer from '../components/Astro/Footer.astro';

// Target Keywords: Προώθηση ξενοδοχείων, Προώθηση Βιλών, Tourism Marketing Κρήτη, Direct Bookings

const title = "Tourism Marketing & Προώθηση Βιλών - Ξενοδοχείων στην Κρήτη | DIGIADS";
const description = "Η No1 εταιρεία στο Tourism Marketing στην Κρήτη. Προώθηση βιλών, ξενοδοχείων και Airbnb. Αυξήστε τα Direct Bookings σας με την DIGIADS.";
---

<Layout title={title} description={description} lang="el">
    <Navbar />

    {/* Hero Split Layout for Luxury Tourism */}
    <section class="relative pt-32 pb-20 bg-[#010205] min-h-screen flex items-center overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(0,183,255,0.05)_0%,transparent_60%)] pointer-events-none" />
        
        <div class="max-w-[1400px] mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center relative z-10 w-full">
            
            {/* Massive AI Visual */}
            <div class="lg:col-span-7 relative group h-[50vh] lg:h-[80vh] w-full rounded-[2rem] overflow-hidden bg-[#0a0d16] border border-white/10 order-2 lg:order-1">
                <img src="/visuals/tourism_luxury.png" alt="Luxury Villa Infinity Pool Crete Tourism" class="w-full h-full object-cover scale-[1.03] group-hover:scale-105 transition-transform duration-[2s] ease-out origin-center" loading="lazy" />
                <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-black/80 to-transparent pointer-events-none"></div>
                <div class="absolute top-8 right-8">
                     <span class="px-4 py-2 bg-black/50 backdrop-blur-md text-white border border-white/20 rounded-full text-xs font-bold tracking-widest uppercase">
                         5★ Premium Guest
                     </span>
                </div>
            </div>

            {/* Text Content */}
            <div class="lg:col-span-5 order-1 lg:order-2 lg:pl-10">
                <span class="text-[#00d9ff] font-mono tracking-[0.2em] uppercase text-xs mb-6 inline-block">Direct Bookings Mastery</span>
                <h1 class="text-4xl md:text-5xl lg:text-7xl font-black text-white font-montserrat tracking-tight leading-[1.1] mb-8">
                    Τουριστικό<br/><span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-[#00d9ff]">Marketing.</span>
                </h1>
                <p class="text-lg text-slate-400 font-light leading-relaxed mb-10">
                    Απελευθερωθείτε από τις εξοντωτικές προμήθειες (15-20%) των πλατφορμών. Αναλαμβάνουμε την πλήρη ψηφιακή ταυτότητα και προώθηση του καταλύματος σας στην Κρήτη (Βίλες & Ξενοδοχεία), προσελκύοντας **Direct Bookings** από Premium πελατολόγιο του εξωτερικού.
                </p>
                
                <div class="space-y-6 mb-12">
                     <div class="flex items-center gap-4 border-l-2 border-[#00d9ff] pl-4">
                         <div class="w-10 h-10 rounded-full bg-blue-500/10 flex items-center justify-center text-blue-400">01</div>
                         <p class="text-white font-bold">Custom Booking Engine Websites</p>
                     </div>
                     <div class="flex items-center gap-4 border-l-2 border-[#00d9ff]/50 pl-4">
                         <div class="w-10 h-10 rounded-full bg-blue-500/10 flex items-center justify-center text-blue-400">02</div>
                         <p class="text-white font-bold">Targeted Google & Meta Ads</p>
                     </div>
                     <div class="flex items-center gap-4 border-l-2 border-[#00d9ff]/20 pl-4">
                         <div class="w-10 h-10 rounded-full bg-blue-500/10 flex items-center justify-center text-blue-400">03</div>
                         <p class="text-white font-bold">Aesthetic Brand Image</p>
                     </div>
                </div>

                <a href="/contact" class="px-8 py-4 bg-gradient-to-r from-[#00d9ff] to-blue-600 text-white font-bold rounded-full hover:scale-105 transition-transform inline-block">
                    ΑΥΞΗΣΤΕ ΤΑ ΚΕΡΔΗ ΣΑΣ
                </a>
            </div>
            
        </div>
    </section>

    <Footer />
</Layout>

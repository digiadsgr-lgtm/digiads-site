---
const { lang = 'el' } = Astro.props;

const data = {
	el: {
		items: [
			{ name: "Digital Marketing", href: "/" },
			{ name: "Κατασκευή Iστοσελίδας", href: "/kataskevi-istoselidon" },
			{
				name: "Υπηρεσίες", href: "/#services", dropdown: [
					{ name: "Business Promotion", href: "/digital-marketing/business-promotion" },
					{ name: "Social Media Management", href: "/digital-marketing/social-media-management" },
					{ name: "Performance Marketing", href: "/digital-marketing/performance-marketing" },
					{ name: "Προώθηση Βιλών – Ξενοδοχείων", href: "/touristiko-marketing" },
				]
			},
            {
				name: "Φωτογραφία & Βίντεο", href: "/photo-services", dropdown: [
					{ name: "Photo Services", href: "/photo-services" },
					{ name: "Drone Services", href: "/photo-services/drone-services" },
				]
			},
			{ name: "Blog", href: "/blog" },
		],
		contact: { name: "Ξεκλείδωσε το Growth Σου", href: "/contact" },
		switcher: { name: "EN", href: "/en", flag: "🇬🇧" }
	},
	en: {
		items: [
			{ name: "Digital Marketing", href: "/en" },
			{ name: "Web Design", href: "/en/web-design" },
            {
				name: "Services", href: "/en/#services", dropdown: [
					{ name: "Business Promotion", href: "/en/performance-marketing" },
					{ name: "Social Media Management", href: "/en/performance-marketing" },
					{ name: "Performance Marketing", href: "/en/performance-marketing" },
					{ name: "Villa - Hotel Promotion", href: "/en/tourism-marketing" },
				]
			},
            {
				name: "Photo & Video", href: "/photo-services", dropdown: [
					{ name: "Photo Services", href: "/photo-services" },
					{ name: "Drone Services", href: "/photo-services/drone-services" },
				]
			},
			{ name: "Blog", href: "/blog" },
		],
		contact: { name: "Unlock Your Growth", href: "/en/contact" },
		switcher: { name: "EL", href: "/", flag: "🇬🇷" }
	}
};

const nav = data[lang];
---
<nav class="absolute top-0 left-0 w-full z-50 px-6 py-6 border-b border-white/5 glass">
    <div class="max-w-[1400px] mx-auto flex justify-between items-center">
        
        {/* Typographic Logo */}
        <a href={lang === 'el' ? '/' : '/en'} class="hover:scale-105 transition-transform flex items-center gap-1 group">
            <span class="text-2xl md:text-3xl font-black text-white tracking-widest font-montserrat">
                DIGI<span class="text-[#00d9ff] group-hover:text-purple-400 transition-colors">ADS</span>
            </span>
        </a>

        {/* Mega Menu */}
        <div class="hidden lg:flex gap-6 text-sm font-medium text-slate-300 items-center">
            {nav.items.map(item => (
                <div class="relative group">
                    <a href={item.href} class="hover:text-[#00d9ff] transition-colors py-4 flex items-center gap-1">
                        {item.name}
                        {item.dropdown && (
                            <svg class="w-3 h-3 group-hover:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                        )}
                    </a>
                    
                    {/* Dropdown Container */}
                    {item.dropdown && (
                        <div class="absolute top-full left-1/2 -translate-x-1/2 mt-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 w-64">
                            <div class="bg-[#030509]/95 backdrop-blur-xl border border-white/10 rounded-xl p-3 shadow-2xl flex flex-col gap-1">
                                {item.dropdown.map(drop => (
                                    <a href={drop.href} class="px-4 py-2 hover:bg-white/5 hover:text-[#00d9ff] rounded-lg transition-colors block text-sm">
                                        {drop.name}
                                    </a>
                                ))}
                            </div>
                        </div>
                    )}
                </div>
            ))}
            
            <a href={nav.contact.href} class="ml-4 px-6 py-2 bg-white/10 rounded-full border border-white/20 hover:bg-[#00d9ff] hover:text-black font-bold hover:border-transparent transition-colors">
                {nav.contact.name}
            </a>
            
            <a href={nav.switcher.href} title={`Switch to ${nav.switcher.name}`} class="ml-2 text-xl opacity-60 hover:opacity-100 hover:scale-110 transition-all flex items-center justify-center">
                {nav.switcher.flag}
            </a>
        </div>
        
        {/* Mobile Menu Button - Interactive for Mobile Agents */}
        <div class="lg:hidden flex items-center gap-4">
            <a href={nav.switcher.href} class="text-xl opacity-60 flex items-center justify-center">{nav.switcher.flag}</a>
            <button id="mobile-menu-btn" aria-label="Toggle Mobile Menu" class="text-white hover:text-[#00d9ff] transition-colors p-2">
                <svg class="w-8 h-8 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"/></svg>
            </button>
        </div>
    </div>

    {/* Mobile Full-Screen Overlay */}
    <div id="mobile-menu-overlay" class="hidden absolute top-full left-0 w-full bg-[#030509]/95 backdrop-blur-3xl border-b border-white/10 flex-col p-6 max-h-[80vh] overflow-y-auto z-40">
        <div class="flex flex-col gap-4">
            {nav.items.map(item => (
                <div class="w-full">
                    <a href={item.href} class="text-xl font-bold text-white block py-3 border-b border-white/5 active:text-[#00d9ff]">{item.name}</a>
                    {item.dropdown && (
                        <div class="pl-4 mt-2 mb-2 flex flex-col gap-3 border-l border-white/10">
                            {item.dropdown.map(drop => (
                                <a href={drop.href} class="text-base text-slate-400 block py-1 active:text-[#00d9ff] transition-colors">{drop.name}</a>
                            ))}
                        </div>
                    )}
                </div>
            ))}
            <a href={nav.contact.href} class="mt-8 px-6 py-4 bg-gradient-to-r from-[#00d9ff] to-purple-500 text-black text-center text-lg font-black tracking-wider uppercase rounded-2xl shadow-[0_0_30px_rgba(0,217,255,0.3)] active:scale-95 transition-transform">
                {nav.contact.name}
            </a>
        </div>
    </div>
</nav>

<script>
    // Vanilla JS Mobile Menu Toggle for 0ms latency mobile execution
    document.addEventListener('DOMContentLoaded', () => {
        const btn = document.getElementById('mobile-menu-btn');
        const menu = document.getElementById('mobile-menu-overlay');
        
        if (btn && menu) {
            btn.addEventListener('click', () => {
                if(menu.classList.contains('hidden')) {
                    menu.classList.remove('hidden');
                    menu.classList.add('flex');
                } else {
                    menu.classList.add('hidden');
                    menu.classList.remove('flex');
                }
            });
        }
    });
</script>

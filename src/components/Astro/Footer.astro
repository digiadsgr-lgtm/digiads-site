---
// Footer.astro
const { lang = 'el' } = Astro.props;

const t = {
	el: {
		ready: "READY TO",
		scale: "SCALE?",
		cta: "Start Your Project",
		contactHref: "/contact",
		servicesTitle: "Υπηρεσίες",
		services: [
			{ name: "Digital Marketing", href: "/digital-marketing/performance-marketing" },
			{ name: "Κατασκευή Ιστοσελίδων", href: "/kataskevi-istoselidon" },
			{ name: "Τουριστικό Marketing", href: "/touristiko-marketing" },
			{ name: "Φωτογραφία & Βίντεο", href: "/photo-services" },
			{ name: "Drone Παραγωγές", href: "/photo-services/drone-services" }
		],
		companyTitle: "Εταιρεία",
		company: [
			{ name: "Η Ομάδα", href: "/#team" },
			{ name: "Blog", href: "/blog" },
			{ name: "Επικοινωνία", href: "/contact" }
		],
		address: "Κολοκοτρώνη 34, Ρέθυμνο, 74132 Κρήτη",
		copy: "DIGIADS Digital Marketing & Web Development. Όλα τα δικαιώματα διατηρούνται."
	},
	en: {
		ready: "READY TO",
		scale: "SCALE?",
		cta: "Start Your Project",
		contactHref: "/en/contact",
		servicesTitle: "Services",
		services: [
			{ name: "Performance Marketing", href: "/en/performance-marketing" },
			{ name: "Web Development", href: "/en/web-design" },
			{ name: "Tourism Marketing", href: "/en/tourism-marketing" },
			{ name: "Photo & Video", href: "/photo-services" },
			{ name: "Drone Productions", href: "/photo-services/drone-services" }
		],
		companyTitle: "Company",
		company: [
			{ name: "Case Studies", href: "/#portfolio" },
			{ name: "Blog", href: "/blog" },
			{ name: "Contact", href: "/en/contact" }
		],
		address: "Kolokotroni 34, Rethymno, 74132 Crete, GR",
		copy: "DIGIADS Digital Marketing & Web Development. All rights reserved."
	}
}[lang];
---
<footer class="relative bg-[#000000] text-white overflow-hidden border-t border-white/5 pt-32 pb-10 z-10">
	{/* Subtle background glow */}
	<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-[radial-gradient(circle_at_center,rgba(0,217,255,0.03)_0%,transparent_70%)] pointer-events-none rounded-full" />
	
	<div class="max-w-[1400px] mx-auto px-6 relative z-10 flex flex-col md:flex-row justify-between mb-32 gap-16 md:gap-8">
		
		{/* Left Side: Massive CTA */}
		<div class="flex-1">
			<h2 class="text-6xl md:text-8xl font-black font-montserrat tracking-tighter leading-[0.85] mb-8">
				<span class="text-slate-500 block">{t.ready}</span>
				<span class="text-white block">{t.scale}</span>
			</h2>
			<a href={t.contactHref} class="group inline-flex items-center gap-4 px-8 py-4 bg-[#00d9ff] text-black rounded-full font-bold uppercase tracking-widest text-sm hover:scale-105 hover:shadow-[0_0_40px_rgba(0,217,255,0.4)] transition-all duration-500">
				{t.cta}
				<svg class="w-5 h-5 group-hover:translate-x-2 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
			</a>
		</div>

		{/* Right Side: SEO Links Matrix */}
		<div class="flex-1 grid grid-cols-1 sm:grid-cols-2 gap-12 sm:gap-6 pt-4">
			<div>
				<h3 class="text-[#00d9ff] font-mono text-xs uppercase tracking-[0.2em] mb-6">{t.servicesTitle}</h3>
				<ul class="flex flex-col gap-4">
					{t.services.map(link => (
						<li>
							<a href={link.href} class="text-lg text-slate-300 hover:text-white hover:translate-x-2 transition-all duration-300 inline-block">
								{link.name}
							</a>
						</li>
					))}
				</ul>
			</div>
			<div>
				<h3 class="text-[#00d9ff] font-mono text-xs uppercase tracking-[0.2em] mb-6">{t.companyTitle}</h3>
				<ul class="flex flex-col gap-4">
					{t.company.map(link => (
						<li>
							<a href={link.href} class="text-lg text-slate-300 hover:text-white hover:translate-x-2 transition-all duration-300 inline-block">
								{link.name}
							</a>
						</li>
					))}
				</ul>
				
				<div class="mt-8 pt-8 border-t border-white/10">
					<p class="text-slate-400 text-sm mb-2 font-mono">{t.address}</p>
					<a href="tel:+306987602707" class="text-2xl font-black text-white hover:text-[#00d9ff] transition-colors">698 760 2707</a>
				</div>
			</div>
		</div>
	</div>

	{/* Giant Typographic SEO Text at the absolute bottom */}
	<div class="w-full relative mt-20 flex justify-center overflow-hidden mix-blend-difference pointer-events-none select-none opacity-20">
		<h1 class="text-[15vw] leading-[0.75] font-black font-montserrat tracking-tighter text-white whitespace-nowrap">
			DIGIADS
		</h1>
	</div>

	{/* Copyright Bar */}
	<div class="max-w-[1400px] mx-auto px-6 mt-10">
		<div class="flex flex-col md:flex-row items-center justify-between py-6 border-t border-white/10 text-xs text-slate-500 font-mono">
			<p>© {new Date().getFullYear()} {t.copy}</p>
			<div class="flex gap-6 mt-4 md:mt-0">
				<a href={lang === 'el' ? "/privacy-policy" : "/en/privacy-policy"} class="hover:text-white transition-colors">Privacy Policy</a>
				<a href="https://www.instagram.com/digiads.gr/" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">Instagram</a>
				<a href="https://www.facebook.com/digiads.gr" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">Facebook</a>
			</div>
		</div>
	</div>
</footer>
